{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/your-org/agentic-plugins-marketplace/main/schemas/plugin.schema.json",
  "title": "Claude Plugin Manifest",
  "description": "Manifest file for a plugin in the Agentic Plugins Marketplace",
  "type": "object",
  "required": ["name", "version", "description", "type", "author"],
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "description": "Unique plugin identifier (kebab-case)",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
    },
    "version": {
      "type": "string",
      "description": "Semantic version (e.g. 1.0.0)",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "description": {
      "type": "string",
      "description": "Short one-line description of what the plugin does"
    },
    "type": {
      "type": "string",
      "description": "Plugin category",
      "enum": ["mcp-server", "skill", "hook", "template"]
    },
    "author": {
      "type": "string",
      "description": "Author name or GitHub handle"
    },
    "license": {
      "type": "string",
      "description": "SPDX license identifier (e.g. MIT, Apache-2.0)",
      "default": "MIT"
    },
    "homepage": {
      "type": "string",
      "format": "uri",
      "description": "Optional link to documentation or project page"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Searchable tags for discovery",
      "minItems": 1,
      "maxItems": 10
    },
    "minClaudeCodeVersion": {
      "type": "string",
      "description": "Minimum Claude Code CLI version required",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "mcp": {
      "type": "object",
      "description": "MCP server configuration (required when type = mcp-server)",
      "required": ["transport"],
      "properties": {
        "transport": {
          "type": "string",
          "enum": ["stdio", "sse"],
          "description": "Transport mechanism for the MCP server"
        },
        "command": {
          "type": "string",
          "description": "Executable to run (e.g. npx, uvx, python)"
        },
        "args": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Arguments passed to the command"
        },
        "env": {
          "type": "object",
          "additionalProperties": { "type": "string" },
          "description": "Environment variables. Use ${VAR_NAME} for values the user must supply."
        },
        "url": {
          "type": "string",
          "format": "uri",
          "description": "Server URL (required for SSE transport)"
        }
      }
    },
    "skill": {
      "type": "object",
      "description": "Skill configuration (required when type = skill)",
      "required": ["file"],
      "properties": {
        "file": {
          "type": "string",
          "description": "Path to the skill .md file relative to the plugin directory"
        },
        "trigger": {
          "type": "string",
          "description": "Optional slash command name (without the leading /)"
        }
      }
    },
    "hook": {
      "type": "object",
      "description": "Hook configuration (required when type = hook)",
      "required": ["event", "command"],
      "properties": {
        "event": {
          "type": "string",
          "description": "Claude Code lifecycle event that triggers this hook",
          "enum": [
            "PreToolUse",
            "PostToolUse",
            "Notification",
            "Stop",
            "SubagentStop"
          ]
        },
        "matcher": {
          "type": "string",
          "description": "Optional tool name pattern to match (for Pre/PostToolUse events)"
        },
        "command": {
          "type": "string",
          "description": "Shell command or path to script to execute"
        }
      }
    },
    "template": {
      "type": "object",
      "description": "Template configuration (required when type = template)",
      "required": ["file"],
      "properties": {
        "file": {
          "type": "string",
          "description": "Path to the CLAUDE.md template file relative to the plugin directory"
        },
        "targetPath": {
          "type": "string",
          "description": "Where to place the file relative to the project root (defaults to CLAUDE.md)",
          "default": "CLAUDE.md"
        }
      }
    }
  },
  "if": { "properties": { "type": { "const": "mcp-server" } } },
  "then": { "required": ["mcp"] },
  "else": {
    "if": { "properties": { "type": { "const": "skill" } } },
    "then": { "required": ["skill"] },
    "else": {
      "if": { "properties": { "type": { "const": "hook" } } },
      "then": { "required": ["hook"] },
      "else": {
        "if": { "properties": { "type": { "const": "template" } } },
        "then": { "required": ["template"] }
      }
    }
  }
}
