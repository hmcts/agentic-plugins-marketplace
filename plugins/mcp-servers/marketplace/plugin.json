{
  "$schema": "../../../schemas/plugin.schema.json",
  "name": "marketplace",
  "version": "1.0.0",
  "description": "MCP server that lets Claude browse, search, and install marketplace plugins as tools",
  "type": "mcp-server",
  "author": "agentic-plugins-marketplace",
  "license": "MIT",
  "tags": ["marketplace", "plugins", "install", "discover", "mcp"],
  "mcp": {
    "transport": "stdio",
    "command": "node",
    "args": ["${MARKETPLACE_DIR}/plugins/mcp-servers/marketplace/server.js"],
    "env": {
      "MARKETPLACE_DIR": "${MARKETPLACE_DIR}"
    }
  }
}
